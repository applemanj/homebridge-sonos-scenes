{
  "pluginAlias": "SonosScenes",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Discovery-driven Sonos scenes and Amp virtual rooms for Homebridge.",
  "footerDisplay": "Use the custom UI to discover players, validate scenes, test execution, and manage virtual rooms.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Sonos Scenes",
        "required": true
      },
      "platform": {
        "title": "Platform",
        "type": "string",
        "default": "SonosScenes",
        "required": true
      },
      "logLevel": {
        "title": "Log Level",
        "type": "string",
        "default": "info",
        "oneOf": [
          "debug",
          "info",
          "warn",
          "error"
        ]
      },
      "defaultHouseholdId": {
        "title": "Default Household Id",
        "type": "string"
      },
      "transport": {
        "title": "Transport",
        "type": "object",
        "properties": {
          "kind": {
            "title": "Kind",
            "type": "string",
            "default": "local",
            "oneOf": [
              "local"
            ]
          },
          "enableLiveDiscovery": {
            "title": "Enable Live Discovery",
            "type": "boolean",
            "default": true
          },
          "fixturePath": {
            "title": "Fixture Path",
            "type": "string"
          },
          "discoveryTimeoutMs": {
            "title": "Discovery Timeout (ms)",
            "type": "integer",
            "default": 2500
          },
          "requestTimeoutMs": {
            "title": "Request Timeout (ms)",
            "type": "integer",
            "default": 5000
          },
          "allowTvSource": {
            "title": "Allow TV Source",
            "type": "boolean",
            "default": false
          }
        }
      },
      "cloud": {
        "title": "Cloud",
        "type": "object",
        "properties": {
          "mode": {
            "title": "Control Mode",
            "type": "string",
            "default": "local_only",
            "oneOf": [
              "local_only",
              "local_plus_cloud"
            ]
          },
          "broker": {
            "title": "Broker",
            "type": "object",
            "properties": {
              "url": {
                "title": "Broker URL",
                "type": "string"
              },
              "apiKey": {
                "title": "Broker API Key",
                "type": "string"
              },
              "timeoutMs": {
                "title": "Broker Timeout (ms)",
                "type": "integer",
                "default": 8000
              },
              "routeFavorites": {
                "title": "Route Favorites Through Broker",
                "type": "boolean",
                "default": true
              },
              "routePlaylists": {
                "title": "Route Playlists Through Broker",
                "type": "boolean",
                "default": true
              }
            }
          }
        }
      },
      "scenes": {
        "title": "Scenes",
        "type": "array",
        "items": {
          "type": "object"
        },
        "default": []
      },
      "virtualRooms": {
        "title": "Virtual Rooms",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "title": "Id",
              "type": "string"
            },
            "name": {
              "title": "Name",
              "type": "string"
            },
            "householdId": {
              "title": "Household Id",
              "type": "string"
            },
            "ampPlayerId": {
              "title": "Amp Player Id",
              "type": "string"
            },
            "channel": {
              "title": "Channel",
              "type": "string",
              "default": "left",
              "oneOf": [
                "left",
                "right"
              ]
            },
            "defaultVolume": {
              "title": "Default Volume",
              "type": "integer",
              "default": 30
            },
            "maxVolume": {
              "title": "Max Volume",
              "type": "integer",
              "default": 100
            },
            "onBehavior": {
              "title": "On Behavior",
              "type": "object",
              "properties": {
                "kind": {
                  "title": "Kind",
                  "type": "string",
                  "default": "restore_last",
                  "oneOf": [
                    "restore_last",
                    "default_volume"
                  ]
                }
              }
            },
            "offBehavior": {
              "title": "Off Behavior",
              "type": "object",
              "properties": {
                "kind": {
                  "title": "Kind",
                  "type": "string",
                  "default": "mute",
                  "oneOf": [
                    "mute",
                    "volume_zero"
                  ]
                }
              }
            },
            "lastActiveBehavior": {
              "title": "Last Active Behavior",
              "type": "object",
              "properties": {
                "kind": {
                  "title": "Kind",
                  "type": "string",
                  "default": "none",
                  "oneOf": [
                    "none",
                    "pause",
                    "stop",
                    "mute_master"
                  ]
                }
              }
            }
          }
        },
        "default": []
      }
    }
  }
}
